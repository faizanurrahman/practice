								"register"
							]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"postman.{{$timestamp}}@example.com\",\n  \"password\": \"{{userPassword}}\",\n  \"displayName\": \"Postman Tester\"\n}"
						},
						"description": "Creates user and returns JWTs. Email must be unique."
					},
					"auth": {
						"type": "noauth"
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
									"const j = pm.response.json();",
									"pm.test('Has token pair', () => {",
									"  pm.expect(j).to.have.property('accessToken');",
									"  pm.expect(j).to.have.property('refreshToken');",
									"});",
									"pm.collectionVariables.set('accessToken', j.accessToken);",
									"pm.collectionVariables.set('refreshToken', j.refreshToken);",
									"pm.collectionVariables.set('registeredEmail', JSON.parse(pm.request.body.raw).email);"
								],
								"type": "text/javascript"
							}
						}
					]
