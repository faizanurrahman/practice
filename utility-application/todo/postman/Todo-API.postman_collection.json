									"pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
									"const j = pm.response.json();",
									"pm.test('Has token pair', () => {",
									"  pm.expect(j).to.have.property('accessToken');",
									"  pm.expect(j).to.have.property('refreshToken');",
